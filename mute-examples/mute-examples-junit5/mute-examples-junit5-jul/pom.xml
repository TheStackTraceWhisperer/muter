<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>io.github.thestacktracewhisperer</groupId>
        <artifactId>mute-examples-junit5</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <artifactId>mute-examples-junit5-jul</artifactId>
    <packaging>jar</packaging>
    <name>mute-examples-junit5-jul</name>
    <description>Example: JUnit 5 + java.util.logging — @Mute silences the root/specific loggers.</description>
    <dependencies>
        <!-- Production code uses java.util.logging — bundled in the JDK, no extra dep -->
        <!-- mute library -->
        <dependency>
            <groupId>io.github.thestacktracewhisperer</groupId>
            <artifactId>mute-junit5-jul</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- JUnit 5 -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
